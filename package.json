{
  "name": "boombust-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:client": "pnpm --filter ./client dev",
    "dev:server": "pnpm --filter ./server dev",
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:server\"",
    "build": "pnpm --filter ./client build",
    "smoke:game": "node scripts/smoke-check-game.mjs"
  },
  "dependencies": {
    "boardgame.io": "^0.50.2"
  },
  "pnpm": {
    "overrides": {
      "@koa/cors": "^5.0.0",
      "cookie": "^1.0.2",
      "engine.io": "^6.6.7",
      "socket.io": "^4.8.3",
      "socket.io-parser": "^4.2.6",
      "svelte": "^5.55.7",
      "ws": "^8.18.3"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
